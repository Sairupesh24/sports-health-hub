# Server
PORT=3000

# Authentication
JWT_SECRET=your_super_secret_jwt_string_change_in_production
JWT_EXPIRES_IN=24h
OTP_EXPIRY_MINUTES=15

# OCI Email Delivery (SMTP)
SMTP_HOST=smtp.email.ap-mumbai-1.oci.oraclecloud.com
SMTP_PORT=587
SMTP_USER=ocid1.user.oc1..example@ocid1.tenancy.oc1..example.com
SMTP_PASS=your_smtp_password
SMTP_FROM=noreply@yourdomain.com

# Database (Optional, defaults to database.sqlite in the server directory)
# DB_PATH=./database.sqlite
